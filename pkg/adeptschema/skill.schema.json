{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://itaywol.github.io/adeptability/schemas/skill.schema.json",
  "title": "Adeptability Skill",
  "type": "object",
  "required": ["id", "version", "description"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_][a-z0-9_-]{0,49}$"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 280
    },
    "activation": {
      "type": "string",
      "enum": ["always", "globs", "agent", "manual"],
      "default": "agent"
    },
    "globs": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "allowed-tools": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "targets": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "size-hint-kib": {
      "type": "integer",
      "minimum": 0
    },
    "metadata": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "activation": { "const": "globs" } }, "required": ["activation"] },
      "then": { "required": ["globs"] }
    }
  ]
}
