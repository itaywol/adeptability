{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://itaywol.github.io/adeptability/schemas/skill.schema.json",
  "title": "Adeptability Skill",
  "type": "object",
  "required": ["id", "description"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]{0,48}[a-z0-9])?$"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 280
    },
    "activation": {
      "type": "string",
      "enum": ["always", "globs", "agent", "manual"],
      "default": "agent"
    },
    "globs": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "allowed-tools": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "targets": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "harness": {
      "type": "object",
      "propertyNames": { "pattern": "^[a-z0-9_][a-z0-9_-]{0,49}$" },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "not": {
          "anyOf": [
            { "required": ["id"] },
            { "required": ["name"] },
            { "required": ["description"] }
          ]
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "activation": { "const": "globs" } }, "required": ["activation"] },
      "then": { "required": ["globs"] }
    }
  ]
}
