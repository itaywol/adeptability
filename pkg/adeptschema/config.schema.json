{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://itaywol.github.io/adeptability/schemas/config.schema.json",
  "title": "Adeptability Project Config",
  "description": "Per-project configuration. Carries ONLY project-level state (enabled harnesses, materialization mode, library remotes). Per-skill state lives on the filesystem.",
  "type": "object",
  "required": ["schema"],
  "additionalProperties": false,
  "properties": {
    "schema": { "type": "integer", "const": 1 },
    "harnesses": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "mode": {
      "type": "string",
      "enum": ["symlink", "copy"]
    },
    "libraries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "remote"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9_][a-z0-9_-]{0,49}$"
          },
          "remote": { "type": "string" },
          "ref": { "type": "string" }
        }
      },
      "uniqueItems": true
    }
  }
}
